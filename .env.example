# Copy to .env for local development. On Heroku, set these as Config Vars.

# REQUIRED
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/wwfngo?retryWrites=true&w=majority
SESSION_SECRET=change-this-to-a-long-random-string

# Admin seed credentials (only used by `npm run create-admin`)
ADMIN_EMAIL=admin@wwfngo.org
ADMIN_PASSWORD=change-me-now
ADMIN_NAME=Site Admin

# OPTIONAL
NODE_ENV=development
PORT=3000
SITE_URL=http://localhost:3000
