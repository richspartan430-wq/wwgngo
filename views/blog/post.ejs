<!DOCTYPE html>
<html lang="en-IN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <meta name="robots" content="index, follow, max-image-preview:large">
  <meta property="og:title" content="<%= post.title %>">
  <meta property="og:description" content="<%= post.excerpt || post.title %>">
  <meta property="og:type" content="article">
  <meta property="og:locale" content="en_IN">
  <% if (post.coverImage) { %>
    <meta property="og:image" content="<%= post.coverImage.startsWith('http') ? post.coverImage : siteUrl + post.coverImage %>">
  <% } %>
  <meta property="article:published_time" content="<%= (post.publishedAt || post.createdAt).toISOString() %>">
  <link rel="canonical" href="<%= siteUrl %>/blog/<%= post.slug %>">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="/favicon_io/favicon.ico">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": <%- JSON.stringify(post.title) %>,
    "description": <%- JSON.stringify(post.excerpt || post.title) %>,
    <% if (post.coverImage) { %>"image": <%- JSON.stringify(post.coverImage.startsWith('http') ? post.coverImage : siteUrl + post.coverImage) %>,<% } %>
    "datePublished": "<%= (post.publishedAt || post.createdAt).toISOString() %>",
    "dateModified": "<%= post.updatedAt.toISOString() %>",
    "author": { "@type": "Organization", "name": "Waste Pickers Welfare Foundation" },
    "publisher": { "@type": "NGO", "name": "Waste Pickers Welfare Foundation", "url": "https://wwfngo.org" },
    "mainEntityOfPage": "<%= siteUrl %>/blog/<%= post.slug %>"
  }
  </script>
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <%- include('../partials/site-nav', { activeNav: 'blog' }) %>

  <main id="main-content">
    <article class="blog-post">
      <p style="margin-bottom: 1rem;"><a href="/blog" style="color:#43A047;">&larr; Back to blog</a></p>
      <h1><%= post.title %></h1>
      <div class="meta">
        <%= new Date(post.publishedAt || post.createdAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        <% if (post.tags && post.tags.length) { %>
          &middot;
          <% post.tags.forEach((t, i) => { %>
            <a href="/blog?tag=<%= encodeURIComponent(t) %>" style="color:#0D47A1;"><%= t %></a><% if (i < post.tags.length - 1) { %>, <% } %>
          <% }) %>
        <% } %>
      </div>
      <% if (post.coverImage) { %>
        <img class="cover" src="<%= post.coverImage %>" alt="<%= post.title %>">
      <% } %>
      <div class="content"><%- post.content %></div>
    </article>

    <% if (related && related.length) { %>
      <section class="blog-page" style="padding-top: 0;">
        <h2 style="margin-bottom: 1rem;">Related posts</h2>
        <div class="blog-grid">
          <% related.forEach(p => { %>
            <article class="blog-card">
              <% if (p.coverImage) { %>
                <a href="/blog/<%= p.slug %>"><img src="<%= p.coverImage %>" alt="<%= p.title %>" loading="lazy"></a>
              <% } %>
              <div class="blog-card-body">
                <h3><a href="/blog/<%= p.slug %>" style="color:inherit; text-decoration:none;"><%= p.title %></a></h3>
                <div class="blog-card-meta"><%= new Date(p.publishedAt || p.createdAt).toLocaleDateString('en-IN') %></div>
                <a href="/blog/<%= p.slug %>" class="read-more">Read &rarr;</a>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>
  </main>

  <%- include('../partials/site-footer') %>
</body>
</html>
